%% ----------------------------------------------------------------
%% TOC / LOF / LOT titles and formatting (完美復刻圖片)
%% ----------------------------------------------------------------
\renewcommand{\contentsname}{目次}
\renewcommand{\listfigurename}{圖次}
\renewcommand{\listtablename}{表次}

% 強制將目錄中所有 Chapter 的標題與頁碼都鎖定為粗體
\renewcommand{\cftchapfont}{\bfseries}      
\renewcommand{\cftchappagefont}{\bfseries}  
\renewcommand{\cftchapleader}{\cftdotfill{\cftdotsep}} 

% 這行是關鍵！它會強行寫入 .toc 暫存檔，確保前面的摘要頁碼也是粗體
\addtocontents{toc}{\protect\renewcommand{\protect\cftchappagefont}{\protect\bfseries}}
\addtocontents{toc}{\protect\renewcommand{\protect\cftchapfont}{\protect\bfseries}}

% ================================================================
% 已修改：讓「圖次」與「表次」呼叫時自動寫入目次
% ================================================================
\let\oldlistoffigures\listoffigures
\renewcommand{\listoffigures}{
  \clearpage
  \addcontentsline{toc}{chapter}{\listfigurename} % 將「圖次」加入目次
  \oldlistoffigures
}

\let\oldlistoftables\listoftables
\renewcommand{\listoftables}{
  \clearpage
  \addcontentsline{toc}{chapter}{\listtablename}  % 將「表次」加入目次
  \oldlistoftables
}
% ================================================================

% ================================================================
% 限制目錄只顯示到第二層（章、節），隱藏小節
\setcounter{tocdepth}{1} 
% ================================================================

\renewcommand{\cfttoctitlefont}{\hfill\bfseries\fontsize{14pt}{14pt}\selectfont}
\renewcommand{\cftaftertoctitle}{\hfill\vspace{-12pt}}
\renewcommand{\cftloftitlefont}{\hfill\bfseries\fontsize{14pt}{14pt}\selectfont}
\renewcommand{\cftafterloftitle}{\hfill\vspace{-12pt}}
\renewcommand{\cftlottitlefont}{\hfill\bfseries\fontsize{14pt}{14pt}\selectfont}
\renewcommand{\cftafterlottitle}{\hfill\vspace{-12pt}}

% ---- 1. 「章」的格式調校 ----
\renewcommand{\cftchapfont}{\normalfont}             % 移除章的粗體，與圖片中的節字體一致
\renewcommand{\cftchappagefont}{\normalfont}         % 移除章頁碼的粗體
\renewcommand{\cftchapleader}{\cftdotfill{\cftdotsep}} % 強制開啟「章」的導引點點點

\renewcommand{\cftchappresnum}{第}                   
\renewcommand{\cftchapaftersnum}{章~~}               
\setlength{\cftchapindent}{0em}                      
