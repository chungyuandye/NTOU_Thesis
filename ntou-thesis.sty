%% ----------------------------------------------------------------
%% Cover & Title Pages
%% ----------------------------------------------------------------
\newcommand{\makeNTOUCover}{%
  \begin{titlepage}
    \thispagestyle{empty}
    \centering
    {\bfseries\fontsize{36pt}{36pt}\selectfont \ntouUniversity\par}\vspace{18pt}
    {\bfseries\fontsize{28pt}{28pt}\selectfont \ntouDepartment\par}\vspace{18pt}
    {\bfseries\fontsize{28pt}{28pt}\selectfont \ntouDegreeZH 學位論文\par}\vspace{40pt}
    {\fontsize{24pt}{24pt}\selectfont 指導教授：\ntouAdvisorZH\par}\vspace{40pt}
    {\bfseries\fontsize{24pt}{24pt}\selectfont \ntouTitleZH\par}\vspace{30pt}
    {\bfseries\fontsize{24pt}{24pt}\selectfont \ntouTitleEN\par}\vfill
    {\fontsize{24pt}{24pt}\selectfont 研究生：\ntouStudentZH\ 撰\par}
    {\fontsize{24pt}{24pt}\selectfont \ntouROCDate\par}
  \end{titlepage}
  \cleardoublepage
}

\newcommand{\makeNTOUTitlePage}{%
  \begin{titlepage}
    \thispagestyle{empty}
    \centering
    {\bfseries\fontsize{24pt}{24pt}\selectfont \ntouTitleZH\par}\vspace{18pt}
    {\bfseries\fontsize{24pt}{24pt}\selectfont \ntouTitleEN\par}\vspace{18pt}
    \IfFileExists{\ntouLogoFile}{%
      \AddToShipoutPictureBG*{%  
        \AtPageCenter{%          
          \makebox(0,0){\includegraphics[width=.60\paperwidth]{\ntouLogoFile}}%
        }%
      }%
    }{}%
    \begin{tabular}{p{.42\linewidth}p{.42\linewidth}}
      研 究 生：\ntouStudentZH & Student：\ntouStudentEN \\
      指導教授：\ntouAdvisorZH & Advisor：\ntouAdvisorEN
    \end{tabular}\vspace{20pt}\par
    {\bfseries\fontsize{14pt}{14pt}\selectfont \ntouUniversity}\\
    {\bfseries\fontsize{14pt}{14pt}\selectfont \ntouDepartment}\\
    {\bfseries\fontsize{14pt}{14pt}\selectfont \ntouDegreeZH 論 文}\\\vspace{18pt}
    A Thesis \\
    Submitted to the \ntouDepartmentEN\\
    \ntouCollegeEN\\
    National Taiwan Ocean University\\
    in partial fulfillment of the requirements\\
    for the Degree of\\
    \ntouDegreeEN\\
    in\\
    \ntouDepartmentEN\par \vfill
    \ntouENDate\par
    Keelung, Taiwan, Republic of China\par
    \vfill
    \ntouROCDate\par
  \end{titlepage}
}

