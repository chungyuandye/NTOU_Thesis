%% ntou-thesis.sty
%% National Taiwan Ocean University thesis template package
%% Based on 國立臺灣海洋大學博、碩士學位論文格式規範 114-08-06.
%% Compile with XeLaTeX.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{ntou-thesis}[2026/05/17 v1.3 NTOU thesis format]

\RequirePackage{iftex}
\ifXeTeX\else
\PackageError{ntou-thesis}{This package requires XeLaTeX}{Compile with XeLaTeX so that Chinese fonts and xeCJK work correctly.}
\fi

%% ----------------------------------------------------------------
%% Page geometry & core packages
%% ----------------------------------------------------------------
\RequirePackage[a4paper,top=2.54cm,bottom=2.54cm,left=3.17cm,right=3.17cm]{geometry}
\RequirePackage{xeCJK}
\RequirePackage{fontspec}
\RequirePackage{setspace}
\RequirePackage{titlesec}
\RequirePackage{titletoc}
\RequirePackage{tocloft}
\RequirePackage{fancyhdr}
\RequirePackage{etoolbox}
\RequirePackage{graphicx}
\RequirePackage{array}
\RequirePackage{booktabs}
\RequirePackage{amsmath}
\RequirePackage{caption}
\RequirePackage{chngcntr}
\RequirePackage{indentfirst}
\RequirePackage{zhnumber}
\RequirePackage{hyperref}
\RequirePackage{xkeyval}
\RequirePackage{setspace}
\RequirePackage{eso-pic}
\RequirePackage{float}
\ExplSyntaxOn
\msg_redirect_name:nnn { fontspec } { script-not-exist } { none }
\ExplSyntaxOff

% ----------------------------------------------------------------
% CJK fonts
% ----------------------------------------------------------------
% ==================== 中英文字體最高權限完美設定 ====================

% 1. 優先處理教育部標準楷書（中文）與指定參數
\IfFileExists{edukai-5.1_20251208.ttf}{%
  \setCJKmainfont{edukai-5.1_20251208.ttf}[
    Path          = ./,
    Script        = Default,
    BoldFont      = edukai-5.1_20251208.ttf,
    ItalicFont    = edukai-5.1_20251208.ttf,
    AutoFakeBold  = 2.5,  % 強制中文標題與章節變粗體
    AutoFakeSlant = 0.2
  ]
  \setCJKsansfont{edukai-5.1_20251208.ttf}[
    Path         = ./,
    Script       = Default,
    BoldFont     = edukai-5.1_20251208.ttf,
    AutoFakeBold = 2.5
  ]
  \setCJKmonofont{edukai-5.1_20251208.ttf}[
    Path         = ./,
    Script       = Default,
    BoldFont     = edukai-5.1_20251208.ttf,
    AutoFakeBold = 2.5
  ]
}{% 2. 如果沒有教育部楷書，才依序往後找原本樣板自帶的 cwTeX 或 Noto 字體
  \IfFileExists{cwTeX Q Kai Medium.ttf}{%
    \setCJKmainfont{cwTeX Q Kai Medium.ttf}[
      Path          = ./,
      Script        = Default,
      BoldFont      = cwTeX Q Kai Medium.ttf,
      ItalicFont    = cwTeX Q Kai Medium.ttf,
      AutoFakeBold  = 2,
      AutoFakeSlant = 0.2
    ]
    \setCJKsansfont{cwTeX Q Kai Medium.ttf}[
      Path         = ./,
      Script       = Default,
      BoldFont     = cwTeX Q Kai Medium.ttf,
      AutoFakeBold = 2
    ]
    \setCJKmonofont{cwTeX Q Kai Medium.ttf}[
      Path         = ./,
      Script       = Default,
      BoldFont     = cwTeX Q Kai Medium.ttf,
      AutoFakeBold = 2
    ]
  }{\IfFileExists{fonts/NotoSansTC-Bold.ttf}{%
      \setCJKmainfont{NotoSerifTC-Regular}[
        Path          = fonts/,
        Extension     = .ttf,
        UprightFont   = *,
        BoldFont      = NotoSerifTC-Bold,
        ItalicFont    = *,
        AutoFakeSlant = 0.2
      ]
      \setCJKsansfont{NotoSansTC-ExtraLight}[
        Path        = fonts/,
        Extension   = .ttf,
        UprightFont = *,
        BoldFont    = NotoSansTC-Bold
      ]
      \setCJKmonofont{NotoSansTC-ExtraLight}[
        Path        = fonts/,
        Extension   = .ttf,
        UprightFont = *,
        BoldFont    = NotoSansTC-Bold
      ]
    }{%
      \setCJKmainfont{Noto Serif CJK TC}[
        BoldFont      = Noto Serif CJK TC Bold,
        ItalicFont    = Noto Serif CJK TC,
        AutoFakeSlant = 0.2
      ]
      \setCJKsansfont{Noto Sans CJK TC}[
        BoldFont = Noto Sans CJK TC Bold
      ]
      \setCJKmonofont{Noto Sans Mono CJK TC}[
        BoldFont = Noto Sans Mono CJK TC Bold
      ]
  }}
}

% 3. 英文與數字主字體設定
\newcommand{\ntouSetMainFont}[1]{%
  \IfFontExistsTF{#1}{%
    \setmainfont{#1}[
      AutoFakeBold = true,
      AutoFakeSlant = true
    ]%
  }{%
    \setmainfont{TeX Gyre Termes}[
      AutoFakeBold = true,
      AutoFakeSlant = true
    ]%
  }%
}
\ntouSetMainFont{Times New Roman}
% ====================================================================

%\setCJKmainfont{edukai-5.1_20251208.ttf}
%% ----------------------------------------------------------------
%% Document-level defaults
%% ----------------------------------------------------------------
\AtBeginDocument{%
  \ntouSetMainFont{\ntoumainfont}%
  \singlespacing
  \setlength{\parindent}{2em}%
  \setlength{\parskip}{0pt}%
  \emergencystretch=3em%
  \hypersetup{hidelinks,hypertexnames=false}%
}

%% ----------------------------------------------------------------
%% Page style
%% ----------------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\cfoot{\thepage}
\fancypagestyle{plain}{%
  \fancyhf{}\cfoot{\thepage}%
  \renewcommand{\headrulewidth}{0pt}%
}
\fancypagestyle{emptyfooter}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

%% ----------------------------------------------------------------
%% 底層計數器設定（讓正文與目錄連動呈現「一、二、三」）
%% ----------------------------------------------------------------
\renewcommand{\thechapter}{\zhnum{chapter}}
\renewcommand{\thesection}{\zhnum{section}}
\renewcommand{\thesubsection}{\arabic{chapter}.\arabic{section}.\arabic{subsection}}

%% ----------------------------------------------------------------
%% Heading formats (規範字級：chapter 16pt, section/subsection 14pt)
%% ----------------------------------------------------------------
\titleformat{\chapter}[block]
{\centering\bfseries\fontsize{16pt}{16pt}\selectfont}
{第{\thechapter}章}{1em}{}
\titlespacing*{\chapter}{0pt}{-1.0cm}{12pt} % 修正上方空白過大

\titleformat{\section}[block]
{\bfseries\fontsize{14pt}{14pt}\selectfont}
{第{\thesection}節}{1em}{}
\titlespacing*{\section}{0pt}{12pt}{6pt}

\titleformat{\subsection}[block]
{\bfseries\fontsize{14pt}{14pt}\selectfont}
{\thesubsection}{1em}{}
\titlespacing*{\subsection}{0pt}{12pt}{6pt}

%% ----------------------------------------------------------------
%% Front-matter centred unnumbered heading
%% ----------------------------------------------------------------
\newcommand{\ntouFrontTitle}[1]{%
  \clearpage
  {\centering\bfseries\fontsize{14pt}{14pt}\selectfont #1\par}%
  \vspace{12pt}%
}

\newcommand{\xfnote}[1]{\par\vspace{2pt}{\footnotesize #1\par}}

