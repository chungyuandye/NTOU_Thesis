%% ----------------------------------------------------------------
%% Front matter / main matter transitions
%% ----------------------------------------------------------------
\newcommand{\NTOUFrontMatter}{%
  \clearpage\pagenumbering{Roman}\setcounter{page}{1}\pagestyle{fancy}%
}
\newcommand{\NTOUMainMatter}{%
  \clearpage\pagenumbering{arabic}\setcounter{page}{1}\pagestyle{fancy}%
}

%% Abstract environments
\newenvironment{NTOUAbstractZH}{\ntouFrontTitle{摘要}}{\par\vspace{12pt}}
\newenvironment{NTOUAbstractEN}{\ntouFrontTitle{Abstract}}{\par\vspace{12pt}}
\newcommand{\NTOUKeywordsZH}[1]{\par\vspace{12pt}關鍵詞：#1。}
\newcommand{\NTOUKeywordsEN}[1]{\par\vspace{12pt}Keywords: #1.}

%% ----------------------------------------------------------------
%% TOC / LOF / LOT titles and formatting
%% ----------------------------------------------------------------
\renewcommand{\contentsname}{目次}
\renewcommand{\listfigurename}{圖次}
\renewcommand{\listtablename}{表次}
\renewcommand{\cfttoctitlefont}{\hfill\bfseries\fontsize{14pt}{14pt}\selectfont}
\renewcommand{\cftaftertoctitle}{\hfill\vspace{12pt}}
\renewcommand{\cftloftitlefont}{\hfill\bfseries\fontsize{14pt}{14pt}\selectfont}
\renewcommand{\cftafterloftitle}{\hfill\vspace{12pt}}
\renewcommand{\cftlottitlefont}{\hfill\bfseries\fontsize{14pt}{14pt}\selectfont}
\renewcommand{\cftafterlottitle}{\hfill\vspace{12pt}}

%% ----------------------------------------------------------------
%% Captions: continuous numbering (not reset per chapter)
%% ----------------------------------------------------------------
\DeclareCaptionLabelSeparator{ntoucolon}{：}
\captionsetup{font=normalsize,labelfont=normalfont,labelsep=ntoucolon,justification=centering}
\renewcommand{\thefigure}{\arabic{figure}}
\renewcommand{\thetable}{\arabic{table}}
\counterwithout{figure}{chapter}
\counterwithout{table}{chapter}
\renewcommand{\figurename}{圖}
\renewcommand{\tablename}{表}

%% ----------------------------------------------------------------
%% Back matter helpers
%% ----------------------------------------------------------------
\newcommand{\NTOUReferences}{%
  \clearpage\chapter*{參考文獻}%
  \addcontentsline{toc}{chapter}{參考文獻}%
}
\newcommand{\NTOUAppendix}{%
  \clearpage\appendix\chapter*{附錄}%
  \addcontentsline{toc}{chapter}{附錄}%
}

\endinput
